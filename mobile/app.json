{
  "expo": {
    "name": "MindFlow",
    "slug": "mindflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F0FDF4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.brainlabs.mindflow"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon-adaptive.png",
        "backgroundColor": "#00000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.brainlabs.mindflow"
    },
    "web": {
      "favicon": "./assets/app-icon-display.png"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-web-browser",
      "expo-notifications",
      "expo-secure-store",
      "expo-av"
    ],
    "extra": {
      "eas": {
        "projectId": "72b9a014-e5e6-426a-94cc-59afd6397133"
      }
    }
  }
}
