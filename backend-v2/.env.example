# Server
PORT=3000
NODE_ENV=development

# Direct Postgres access (Supavisor pooler connection string, transaction
# mode recommended — see plans/backend-go-migration.md §3). Not the same
# value as backend/'s Supabase client keys.
DATABASE_URL=postgresql://app_backend_v2:password@your-project-pooler.supabase.com:6543/postgres?sslmode=require

# Supabase project (used for JWKS/JWT verification and Auth API proxying
# in later phases; SUPABASE_URL is required from phase 1 onward)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS (comma-separated origins for production)
# CORS_ORIGINS=https://admin.mindflow.app,https://app.mindflow.app

# Trusts one reverse-proxy hop by default; set to 0 to trust none.
# TRUST_PROXY_HOPS=1
